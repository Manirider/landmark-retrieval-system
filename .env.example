# ==================================================
# Landmark Retrieval System — Environment Variables
# ==================================================
# Copy this file to .env and customize as needed.

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Model Artifacts
MODEL_PATH=artifacts/model.pth
INDEX_PATH=artifacts/landmarks.index
ID_MAPPING_PATH=artifacts/id_mapping.npy
LANDMARK_MAP_PATH=data/landmark_map.json

# Retrieval Settings
TOP_K=5
EMBEDDING_DIM=128

# Training Settings
LEARNING_RATE=0.001
BATCH_SIZE=32
NUM_EPOCHS=20
MARGIN=0.3

# Dataset Settings
NUM_CLASSES=50
MIN_IMAGES_PER_CLASS=10
TRAIN_SPLIT=0.8

# Logging
LOG_LEVEL=INFO
